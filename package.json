{
  "name": "epicenter-city",
  "version": "1.0.0",
  "description": "Survive the neon metropolis. Build your legacy.",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "Epicenter Studios",
  "license": "MIT",
  "dependencies": {
    "steamworks-ffi-node": "^0.10.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.epicenterstudios.epicentercity",
    "productName": "EPICENTER CITY",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**",
      "electron-main.js",
      "preload.js",
      "index.html",
      "!steam_api64.dll", 
      "!libsteam_api.so",
      "!libsteam_api.dylib"
    ],
    "extraFiles": [
      {
        "from": "steamworks_sdk",
        "to": "steamworks_sdk"
      }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png",
      "category": "Game"
    },
    "mac": {
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
